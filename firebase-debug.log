[debug] [2026-07-15T01:54:51.242Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/br-chess/rulesets {"name":"projects/br-chess/rulesets/4f226676-ef7d-4c4c-a90c-c111356317cd","source":{"files":[{"content":"rules_version = '2';\n\n// Firestore security rules for br-chess (the named `chessified` database).\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    // Workspace nodes: folders and pgn-grid files, scoped to their owner.\n    // Every node must carry `ownerId` equal to the signed-in user's uid, and a\n    // user may only touch their own nodes — reads, deletes, and the pre-update\n    // document are checked against the stored owner, while creates and the\n    // post-update document must stamp the caller's own uid (so a node can't be\n    // created for, reassigned to, or stolen from another user).\n    match /nodes/{nodeId} {\n      allow read: if request.auth != null\n        && resource.data.ownerId == request.auth.uid;\n      allow create: if request.auth != null\n        && request.resource.data.ownerId == request.auth.uid;\n      allow update: if request.auth != null\n        && resource.data.ownerId == request.auth.uid\n        && request.resource.data.ownerId == request.auth.uid;\n      allow delete: if request.auth != null\n        && resource.data.ownerId == request.auth.uid;\n    }\n    // Deny everything outside the known collection.\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-07-15T01:54:50.416399Z","metadata":{"services":["cloud.firestore"]},"attachmentPoint":"firestore.googleapis.com/projects/653364172198/databases/chessified"}
