rules_version = '2';

// Firestore security rules for br-chess (the named `chessified` database).
service cloud.firestore {
  match /databases/{database}/documents {
    // Workspace nodes: folders and pgn-grid files, scoped to their owner.
    // Every node must carry `ownerId` equal to the signed-in user's uid, and a
    // user may only touch their own nodes — reads, deletes, and the pre-update
    // document are checked against the stored owner, while creates and the
    // post-update document must stamp the caller's own uid (so a node can't be
    // created for, reassigned to, or stolen from another user).
    match /nodes/{nodeId} {
      allow read: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }
    // Deny everything outside the known collection.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
